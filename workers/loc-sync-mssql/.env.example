# ── Supabase (service role — NIKAD u browser bundle-u) ───────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...SERVICE_ROLE...

# ── MSSQL (target baza sa sp_ApplyLocationEvent) ─────────────────────────
MSSQL_HOST=sql.servoteh.local
MSSQL_PORT=1433
MSSQL_USER=loc_sync_worker
MSSQL_PASSWORD=change_me
MSSQL_DATABASE=ServoTehERP
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERT=true

# ── Worker podešavanja ───────────────────────────────────────────────────
WORKER_ID=loc-sync-worker-1
BATCH_SIZE=10
POLL_INTERVAL_MS=5000
# Kada nema event-a, čekaj duže (štedi DB roundtrip-ove):
IDLE_INTERVAL_MS=15000
# Log level: debug | info | warn | error
LOG_LEVEL=info
