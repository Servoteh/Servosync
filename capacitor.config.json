{
  "appId": "com.servoteh.lokacije",
  "appName": "Servosync",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "capacitor"
  },
  "ios": {
    "contentInset": "automatic",
    "scheme": "Servoteh Lokacije",
    "allowsLinkPreview": false,
    "preferredContentMode": "mobile"
  },
  "plugins": {
    "BarcodeScanner": {
      "googleBarcodeScannerModuleInstallState": "moduleAvailable"
    }
  }
}
